@startuml SGISI - Diagrama de Clases de Diseño

skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor White
  BorderColor      #2C6EA6
  ArrowColor       #555555
  FontSize         10
}
skinparam interface {
  BackgroundColor #D6EAF8
  BorderColor     #2C6EA6
}
skinparam enum {
  BackgroundColor #EBF5FB
  BorderColor     #2C6EA6
}
skinparam package {
  BackgroundColor #F8F9F9
  BorderColor     #AAB7B8
  FontSize        11
  FontStyle       bold
}
skinparam arrow {
  FontSize 9
}

' ================================================================
' CAPA DE MODELO – Entidades del dominio
' ================================================================
package "modelo" {

  abstract class Usuario {
    # id            : int
    # nombre        : String
    # apellido      : String
    # email         : String
    # legajo        : String
    # contrasenaHash: String
    # activo        : boolean
    # fechaCreacion : LocalDateTime
    + getId()       : int
    + getEmail()    : String
    + isActivo()    : boolean
    + {abstract} getRol() : RolUsuario
  }

  class AnalistaSoc {
    + getRol()            : RolUsuario
    + registrarIncidente(inc : Incidente) : void
    + actualizarEstado(inc : Incidente, nuevoEstado : String, obs : String) : void
    + registrarEvidencia(ev : Evidencia)  : void
    + escalarIncidente(inc : Incidente, motivo : String) : void
  }

  class SupervisorSeguridad {
    + getRol()            : RolUsuario
    + asignarIncidente(inc : Incidente, analista : AnalistaSoc) : void
    + revisarVencimientosSLA() : List<Incidente>
    + generarReporte(desde : LocalDate, hasta : LocalDate) : ReporteGestion
  }

  class Administrador {
    + getRol()                      : RolUsuario
    + gestionarUsuarios()           : void
    + consultarBitacora(incId : int): List<EntradaBitacora>
  }

  enum RolUsuario {
    ANALISTA_SOC
    SUPERVISOR_SEGURIDAD
    ADMINISTRADOR
  }

  Usuario <|-- AnalistaSoc
  Usuario <|-- SupervisorSeguridad
  Usuario <|-- Administrador
  Usuario ..> RolUsuario

  ' ── Incidente ──────────────────────────────────────────────
  class Incidente {
    - id                  : int
    - descripcion         : String
    - fechaDeteccion      : LocalDateTime
    - fechaAsignacion     : LocalDateTime
    - fechaCierre         : LocalDateTime
    - fechaVencimientoSLA : LocalDateTime
    - motivoEscalada      : String
    - tipo                : TipoIncidente
    - severidad           : NivelSeveridad
    - estado              : EstadoIncidenteState
    - activoAfectado      : ActivoAfectado
    - analistaAsignado    : AnalistaSoc
    - supervisorAsignado  : SupervisorSeguridad
    + getId()             : int
    + getEstado()         : EstadoIncidenteState
    + setEstado(e : EstadoIncidenteState) : void
    + calcularMTTD()      : Duration
    + calcularMTTR()      : Duration
    + isSLAVencido()      : boolean
  }

  enum TipoIncidente {
    ACCESO_NO_AUTORIZADO
    MALWARE
    PHISHING
    FUGA_DE_DATOS
    DENEGACION_DE_SERVICIO
    FRAUDE_TRANSACCIONAL
  }

  enum NivelSeveridad {
    CRITICO
    ALTO
    MEDIO
    BAJO
  }

  class ActivoAfectado {
    - id         : int
    - nombre     : String
    - tipo       : String
    - descripcion: String
    + getId()    : int
    + getNombre(): String
  }

  class ConfiguracionSLA {
    - id          : int
    - severidad   : NivelSeveridad
    - plazoHoras  : int
    + calcularVencimiento(fechaDeteccion : LocalDateTime) : LocalDateTime
    + estaVencido(inc : Incidente)  : boolean
    + getPlazoHoras() : int
  }

  class Evidencia {
    - id                : int
    - tipoEvidencia     : String
    - descripcion       : String
    - fechaRegistro     : LocalDateTime
    + getId()           : int
    + getTipoEvidencia(): String
  }

  class EntradaBitacora {
    - id        : int
    - fechaHora : LocalDateTime
    - accion    : String
    - detalle   : String
    + getId()   : int
    + getAccion(): String
  }

  Incidente     ..>  TipoIncidente
  Incidente     ..>  NivelSeveridad
  Incidente     -->  ActivoAfectado    : afecta >
  Incidente     -->  ConfiguracionSLA  : se rige por >
  ConfiguracionSLA ..> NivelSeveridad
  Incidente "1" *--> "0..*" Evidencia       : contiene >
  Incidente "1" *--> "1..*" EntradaBitacora : registra >
}

' ================================================================
' PATRÓN STATE – Ciclo de vida del incidente
' ================================================================
package "modelo.estado" {

  interface EstadoIncidenteState {
    + getNombreEstado()              : String
    + getTransicionesValidas()       : List<String>
    + puedeTransicionarA(nuevoEstado : String) : boolean
  }

  class EstadoDetectado {
    + getNombreEstado()              : String
    + getTransicionesValidas()       : List<String>
    + puedeTransicionarA(nuevoEstado : String) : boolean
  }

  class EstadoEnAnalisis {
    + getNombreEstado()              : String
    + getTransicionesValidas()       : List<String>
    + puedeTransicionarA(nuevoEstado : String) : boolean
  }

  class EstadoContenido {
    + getNombreEstado()              : String
    + getTransicionesValidas()       : List<String>
    + puedeTransicionarA(nuevoEstado : String) : boolean
  }

  class EstadoEnRemediacion {
    + getNombreEstado()              : String
    + getTransicionesValidas()       : List<String>
    + puedeTransicionarA(nuevoEstado : String) : boolean
  }

  class EstadoCerrado {
    + getNombreEstado()              : String
    + getTransicionesValidas()       : List<String>
    + puedeTransicionarA(nuevoEstado : String) : boolean
  }

  class EstadoFalsoPositivo {
    + getNombreEstado()              : String
    + getTransicionesValidas()       : List<String>
    + puedeTransicionarA(nuevoEstado : String) : boolean
  }

  EstadoIncidenteState <|.. EstadoDetectado
  EstadoIncidenteState <|.. EstadoEnAnalisis
  EstadoIncidenteState <|.. EstadoContenido
  EstadoIncidenteState <|.. EstadoEnRemediacion
  EstadoIncidenteState <|.. EstadoCerrado
  EstadoIncidenteState <|.. EstadoFalsoPositivo
}

' Incidente delega la validación de transición al estado actual
Incidente --> EstadoIncidenteState : estado >

' ================================================================
' CAPA DAO – Interfaces y acceso a datos
' ================================================================
package "dao" {

  interface IncidenteDAO {
    + guardar(inc : Incidente) : void
    + buscarPorId(id : int)    : Incidente
    + listarAbiertos()         : List<Incidente>
    + listarConFiltros(tipo : String, severidad : String, estado : String, desde : LocalDate, hasta : LocalDate) : List<Incidente>
    + actualizar(inc : Incidente) : void
    + calcularMTTR(desde : LocalDate, hasta : LocalDate) : Map<String, Double>
  }

  interface UsuarioDAO {
    + guardar(u : Usuario)          : void
    + buscarPorEmail(email : String): Usuario
    + buscarPorId(id : int)         : Usuario
    + listarPorRol(rol : RolUsuario): List<Usuario>
    + actualizar(u : Usuario)       : void
  }

  interface EvidenciaDAO {
    + guardar(ev : Evidencia)              : void
    + listarPorIncidente(incId : int)      : List<Evidencia>
    + eliminar(id : int)                   : void
  }

  interface BitacoraDAO {
    + registrar(entrada : EntradaBitacora) : void
    + listarPorIncidente(incId : int)      : List<EntradaBitacora>
  }

  interface SlaDAO {
    + buscarPorSeveridad(sev : NivelSeveridad) : ConfiguracionSLA
    + listarTodos()                             : List<ConfiguracionSLA>
  }

  class ConexionDB <<Singleton>> {
    - {static} instancia : ConexionDB
    - url       : String
    - usuario   : String
    - contrasena: String
    - ConexionDB()
    + {static} getInstancia()          : ConexionDB
    + getConexion()                    : Connection
    + cerrarConexion(conn : Connection): void
  }
}

package "dao.impl" {

  class IncidenteDAOImpl {
    - conexionDB : ConexionDB
    + guardar(inc : Incidente) : void
    + buscarPorId(id : int)    : Incidente
    + listarAbiertos()         : List<Incidente>
    + listarConFiltros(...)    : List<Incidente>
    + actualizar(inc : Incidente) : void
    + calcularMTTR(...)        : Map<String, Double>
  }

  class UsuarioDAOImpl {
    - conexionDB : ConexionDB
    + guardar(u : Usuario)          : void
    + buscarPorEmail(email : String): Usuario
    + buscarPorId(id : int)         : Usuario
    + listarPorRol(rol : RolUsuario): List<Usuario>
    + actualizar(u : Usuario)       : void
  }

  class EvidenciaDAOImpl {
    - conexionDB : ConexionDB
    + guardar(ev : Evidencia)         : void
    + listarPorIncidente(incId : int) : List<Evidencia>
    + eliminar(id : int)              : void
  }

  class BitacoraDAOImpl {
    - conexionDB : ConexionDB
    + registrar(entrada : EntradaBitacora) : void
    + listarPorIncidente(incId : int)      : List<EntradaBitacora>
  }

  class SlaDAOImpl {
    - conexionDB : ConexionDB
    + buscarPorSeveridad(sev : NivelSeveridad) : ConfiguracionSLA
    + listarTodos()                             : List<ConfiguracionSLA>
  }

  IncidenteDAOImpl ..|> IncidenteDAO
  UsuarioDAOImpl   ..|> UsuarioDAO
  EvidenciaDAOImpl ..|> EvidenciaDAO
  BitacoraDAOImpl  ..|> BitacoraDAO
  SlaDAOImpl       ..|> SlaDAO

  IncidenteDAOImpl --> ConexionDB
  UsuarioDAOImpl   --> ConexionDB
  EvidenciaDAOImpl --> ConexionDB
  BitacoraDAOImpl  --> ConexionDB
  SlaDAOImpl       --> ConexionDB
}

' ================================================================
' CAPA DE SERVICIO – Lógica de negocio
' ================================================================
package "servicio" {

  class GestorIncidentes {
    - incidenteDAO : IncidenteDAO
    - bitacoraDAO  : BitacoraDAO
    - gestorSLA    : GestorSLA
    + registrarIncidente(inc : Incidente, usuario : Usuario) : Incidente
    + asignarIncidente(incId : int, analistaId : int, supervisor : SupervisorSeguridad) : void
    + cambiarEstado(incId : int, nuevoEstado : String, obs : String, usuario : Usuario) : void
    + escalarIncidente(incId : int, motivo : String, analista : AnalistaSoc) : void
    + consultarIncidentes(filtros : Map) : List<Incidente>
  }

  class GestorUsuarios {
    - usuarioDAO : UsuarioDAO
    + autenticar(email : String, contrasena : String) : Usuario
    + crearUsuario(u : Usuario)  : void
    + desactivarUsuario(id : int): void
    + listarAnalistas()          : List<AnalistaSoc>
  }

  class GestorSLA {
    - slaDAO       : SlaDAO
    - incidenteDAO : IncidenteDAO
    + calcularVencimiento(inc : Incidente)  : LocalDateTime
    + verificarVencidos()                   : List<Incidente>
    + estaVencido(inc : Incidente)          : boolean
  }

  class GestorReportes {
    - incidenteDAO : IncidenteDAO
    + generarReporte(desde : LocalDate, hasta : LocalDate) : ReporteGestion
    + calcularMTTD(incidentes : List<Incidente>)           : double
    + calcularMTTR(incidentes : List<Incidente>)           : double
  }

  class ReporteGestion {
    - periodo              : String
    - totalIncidentes      : int
    - incidentesPorTipo    : Map<String, Integer>
    - incidentesPorSeveridad : Map<String, Integer>
    - mttdPromedio         : double
    - mttrPromedio         : double
    - cargaPorAnalista     : Map<String, Integer>
    + getTotalIncidentes() : int
    + getMttdPromedio()    : double
    + getMttrPromedio()    : double
  }

  GestorIncidentes --> IncidenteDAO
  GestorIncidentes --> BitacoraDAO
  GestorIncidentes --> GestorSLA
  GestorUsuarios   --> UsuarioDAO
  GestorSLA        --> SlaDAO
  GestorSLA        --> IncidenteDAO
  GestorReportes   --> IncidenteDAO
  GestorReportes   ..> ReporteGestion : crea >
}

' ================================================================
' CAPA DE PRESENTACIÓN – Interfaz Swing
' ================================================================
package "presentacion" {

  class VentanaPrincipal {
    - usuarioActual    : Usuario
    - gestorIncidentes : GestorIncidentes
    - gestorSLA        : GestorSLA
    + inicializar(usuario : Usuario) : void
    + mostrarPanel(panel : String)   : void
  }

  class DialogLogin {
    - gestorUsuarios : GestorUsuarios
    + validarCredenciales() : Usuario
  }

  class PanelListaIncidentes {
    - gestorIncidentes : GestorIncidentes
    + cargarIncidentes()  : void
    + aplicarFiltros()    : void
    + abrirFormRegistro() : void
  }

  class FormRegistroIncidente {
    - gestorIncidentes : GestorIncidentes
    + guardarIncidente() : void
    + validarCampos()    : boolean
  }

  class PanelDetalleIncidente {
    - gestorIncidentes : GestorIncidentes
    + cargarDetalle(incId : int) : void
    + cambiarEstado()            : void
    + agregarEvidencia()         : void
  }

  class PanelReportes {
    - gestorReportes : GestorReportes
    + generarReporte() : void
    + mostrarResultado(rep : ReporteGestion) : void
  }

  VentanaPrincipal     --> DialogLogin
  VentanaPrincipal     --> PanelListaIncidentes
  VentanaPrincipal     --> PanelReportes
  PanelListaIncidentes --> FormRegistroIncidente
  PanelListaIncidentes --> PanelDetalleIncidente
  DialogLogin          --> GestorUsuarios
  PanelListaIncidentes --> GestorIncidentes
  FormRegistroIncidente --> GestorIncidentes
  PanelDetalleIncidente --> GestorIncidentes
  PanelReportes        --> GestorReportes
}

@enduml
