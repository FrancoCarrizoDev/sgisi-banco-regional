    component "Servidor de Archivos\n(logs, evidencias)\n192.168.20.101" as FS
  }

  ' в”Ђв”Ђ VLAN GestiГіn в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  node "VLAN 30 вЂ“ GestiГіn\n192.168.30.0/24" as VLAN_MGT {
    component "Consola de AdministraciГіn\nDBA / Sysadmin\n192.168.30.10" as ADM
  }

  ' в”Ђв”Ђ ACL entre VLANs (firewall interno) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  component "Firewall Interno / ACL Inter-VLAN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPERMIT TCP 192.168.10.0/24 в†’ 192.168.20.100:3306\nPERMIT TCP 192.168.30.0/24 в†’ 192.168.20.100:3306\nDENY  ANY в†’ 192.168.20.100:3306" as ACL_INT
}

' в”Ђв”Ђ Relaciones в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

